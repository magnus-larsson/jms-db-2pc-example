 * Create application queues
DEFINE QLOCAL('inbound.queue') REPLACE
DEFINE QLOCAL('DEV.DEAD.LETTER.QUEUE') REPLACE
DEFINE QLOCAL('request.queue') REPLACE
DEFINE QLOCAL('reply.queue') REPLACE

* Set permissions for app user
SET AUTHREC PROFILE('inbound.queue') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(ALL)
SET AUTHREC PROFILE('DEV.DEAD.LETTER.QUEUE') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(ALL)
SET AUTHREC PROFILE('request.queue') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(ALL)
SET AUTHREC PROFILE('reply.queue') OBJTYPE(QUEUE) PRINCIPAL('app') AUTHADD(ALL)
